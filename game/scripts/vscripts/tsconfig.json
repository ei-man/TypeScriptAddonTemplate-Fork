{
    "compilerOptions": {
        "rootDir": ".",
        "target": "esnext",
        "lib": ["esnext"],
        "types": ["../../../dota_types/lua/normalized"],
        "plugins": [{ "transform": "../../../dota_types/lua/transformer" }],
        "moduleResolution": "node",
        "strict": true
    },
    "tstl": {
        "luaTarget": "JIT",
        "sourceMapTraceback": true
    },
    "include": ["**/*.ts", "../../../common_dts/**/*.ts"]
}
